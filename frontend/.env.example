# ── Firebase ──────────────────────────────────────────────────────────────────
# Firebase console → Project settings → General → Your apps → Web app config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firebase console → Project settings → Cloud Messaging → Web Push certificates
VITE_FIREBASE_VAPID_KEY=

# ── Instagram oEmbed ─────────────────────────────────────────────────────────
# Meta for Developers → your app → token → raises rate limit from 200 to 5000 req/hr
# Optional: leave empty to use the public (unauthenticated) oEmbed endpoint
VITE_OEMBED_TOKEN=

# ── OCR Server (Railway) ──────────────────────────────────────────────────────
# Set after deploying ocr-server/ to Railway
VITE_OCR_SERVER_URL=https://your-app.railway.app

# ── Google AdSense ────────────────────────────────────────────────────────────
# AdSense console → Sites → your site → Get code → data-ad-client value
VITE_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
# Ad unit IDs from AdSense console → Ads → By ad unit
VITE_ADSENSE_SLOT_TIMELINE=XXXXXXXXXX
VITE_ADSENSE_SLOT_DETAIL=XXXXXXXXXX

# ── Kakao Adfit ───────────────────────────────────────────────────────────────
# Kakao Adfit console → 광고단위 관리 → 단위 ID
VITE_ADFIT_UNIT_ID=DAN-XXXXXXXXXXXXXXXXXX