# Firebase Admin SDK + Google Cloud Vision API 공용 서비스 계정 키
# (Firestore 쓰기 + Vision API 권한 모두 부여된 SA 키를 한 줄 JSON으로 입력)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Vision API 전용 키가 별도인 경우 아래에 입력 (없으면 위 키를 자동 사용)
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}

# Naver Shopping API
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=