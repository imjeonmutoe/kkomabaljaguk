# Firebase Admin SDK — base64-encoded service account JSON
# Generate: base64 -i serviceAccountKey.json | tr -d '\n'
FIREBASE_CREDENTIALS=

FIREBASE_PROJECT_ID=

# Naver Shopping Search API
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# OCR settings
OCR_CONFIDENCE_MIN=0.7
MAX_IMAGE_MB=5

# CORS — your Vercel frontend URL
FRONTEND_ORIGIN=https://your-app.vercel.app